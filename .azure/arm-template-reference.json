{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Reference ARM template - use Azure Portal or CLI for actual deployment",
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "name": "lexiguard-plan",
      "apiVersion": "2022-03-01",
      "location": "[resourceGroup().location]",
      "sku": { "name": "B1", "tier": "Basic" },
      "kind": "linux",
      "properties": { "reserved": true }
    },
    {
      "type": "Microsoft.Web/sites",
      "name": "lexiguard-api",
      "apiVersion": "2022-03-01",
      "location": "[resourceGroup().location]",
      "dependsOn": ["lexiguard-plan"],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', 'lexiguard-plan')]",
        "siteConfig": {
          "linuxFxVersion": "NODE|20-lts",
          "appSettings": [
            { "name": "NODE_ENV", "value": "production" },
            { "name": "AZURE_KEY_VAULT_URL", "value": "https://lexiguard-vault.vault.azure.net/" }
          ]
        }
      }
    }
  ]
}